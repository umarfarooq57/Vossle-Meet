# ====================================
# Vossle Server — Environment Config
# ====================================

# Server
PORT=5000
NODE_ENV=development

# JWT Secrets
JWT_SECRET=vossle_jwt_secret_change_in_production_2026
JWT_REFRESH_SECRET=vossle_refresh_secret_change_in_production_2026
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS (comma-separated for multiple origins)
CLIENT_URL=https://your-vercel-app.vercel.app,http://localhost:3000

# TURN/STUN Servers
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=vossle
TURN_CREDENTIAL=vossle_turn_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
